# =============================================================================
# FLXContabilidad Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in real values.
# Environment-specific overrides go in .env.development or .env.production.
# Set APP_ENV=development or APP_ENV=production to select the overlay.

# --- Environment ---
APP_ENV=production

# --- Flask ---
SECRET_KEY=CHANGE_ME_generate_with_python_c_import_secrets_secrets_token_hex_32
FLASK_DEBUG=False

# --- SQLite Auth DB ---
SQLITE_DB_PATH=./backend/users.db

# --- SQL Server (Data Source) ---
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_SERVER=host,port
DB_DATABASE=database_name
DB_UID=username
DB_PWD=password
DB_ENCRYPT=yes
DB_TRUST_CERT=yes
DB_CONNECT_TIMEOUT=30
DB_QUERY_TIMEOUT=120
DB_POOL_SIZE=8
FETCH_MAX_WORKERS=5

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Session ---
# Override this per-environment when multiple instances share a host (e.g. prod
# on :80 and staging on :8081 — browsers key cookies by domain only, ignoring
# port, so without distinct names the two services share/clobber the cookie).
SESSION_COOKIE_NAME=session

# --- Output ---
OUTPUT_DIR=./output
LOG_LEVEL=INFO
